# Firebase Admin SDK Configuration
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30d

# Server
PORT=3000
NODE_ENV=development

# CORS — set to your frontend domain in production
ALLOWED_ORIGIN=https://your-frontend-domain.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Resend API (https://resend.com — free tier: 3,000 emails/month)
# Sign up at resend.com → API Keys → Create API Key → paste below
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be from a verified domain in your Resend account
# e.g. "UPI Tracker <noreply@yourdomain.com>"
RESEND_FROM_EMAIL=UPI Tracker <noreply@yourdomain.com>
